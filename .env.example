# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Database (MySQL/MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=loanmanagement

# Connection Pool (tune for production)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=20000
DB_POOL_IDLE=10000
DB_LOGGING=false

# Security - REQUIRED for production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN_SECRET=
SESSION_SECRET=

# CORS - Comma-separated allowed origins
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000

# OpenAI (optional - mock responses used if not set)
OPENAI_API_KEY=
